# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  ULTRA-GURU — Environment Variables
#
#  INSTRUCTIONS:
#    1. Copy this file to the PROJECT ROOT and rename it to:  .env
#       (i.e. place it alongside index.js, package.json)
#    2. Fill in your SESSION_ID below
#    3. Restart the bot
#
#  SESSION_ID format:   GURU~<base64data>
#  Get yours from the pairing page / session generator.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

SESSION_ID=GURU~paste_your_session_data_here

# Optional settings (leave blank to use bot defaults)
MODE=
TIME_ZONE=
AUTO_READ_STATUS=
AUTO_LIKE_STATUS=
DATABASE_URL=
